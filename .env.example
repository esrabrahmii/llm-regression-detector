# Used by the LLM-under-test (the ml-research-agent's planner).
# Get one free at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Used by the LLM-as-judge scorer + the embedding scorer.
# Get one free at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# Where ml-research-agent lives (so we can import its planner as the SUT)
MLRA_PATH=../ml-research-agent

# Optional: real Slack webhook. If unset, alerts are written to alerts/<ts>_<run_id>.json
# (the demo flow uses the simulated path).
SLACK_WEBHOOK_URL=
